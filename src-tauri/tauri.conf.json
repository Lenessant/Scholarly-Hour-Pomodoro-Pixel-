{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scholar-hour",
  "version": "0.1.1",
  "identifier": "scholarhour",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "scholar-hour",
        "width": 366,
        "height": 512,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "minimizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMzEwOTkzNkNGMDAxMTMKUldRVEFmQnNrd2t4RW83ellGWmNyeGtPc3BCZHFsV1BqdHZEdzBVZFRON3lHaWVkKzIrcE5WMDYK",
      "endpoints": [
        "https://github.com/Lenessant/scholar-hour/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}